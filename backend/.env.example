# FastAPI Server Settings
PORT=8000
HOST=0.0.0.0

# Database Configuration
# For SQLite, use sqlite:///./plotcrm.db
DATABASE_URL=sqlite:///./plotcrm.db

# JWT Security
# You can generate a random secret key using: openssl rand -hex 32
JWT_SECRET_KEY=9a3f2b6e1c7d8a9f0e2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI — Groq (primary): https://console.groq.com/keys
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile
# Optional Gemini fallback: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Frontend URL for QR codes, plot links, and CORS (set to your Vercel URL in production)
FRONTEND_URL=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173

# Optional: extra CORS origins (comma-separated), e.g. preview deploy URLs
# CORS_ORIGINS=https://plotcrm-git-main.vercel.app

# Production PostgreSQL (Render) — replace sqlite URL when using a managed DB:
# DATABASE_URL=postgresql://user:pass@host/dbname
